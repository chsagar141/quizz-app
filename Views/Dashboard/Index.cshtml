@{
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .container-center {
        padding-top: 40px;
    }

    .glass-box {
        background: rgba(0, 0, 0, 0.4);
        padding: 30px;
        border-radius: 15px;
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        color: white;
    }

    .quiz-card {
        background: rgba(255, 255, 255, 0.2);
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 10px;
    }

    .btn-custom {
        background: #0d6efd;
        border: none;
    }

    .btn-custom:hover {
        background: #0b5ed7;
    }
</style>

<div class="container container-center">
    <div class="glass-box">

        <h2>Welcome, @ViewBag.Username 👋</h2>

        @if (ViewBag.Role == "Teacher")
        {
            <h4 class="mt-3">Teacher Dashboard</h4>

            <a class="btn btn-custom mt-2 mb-3"
               asp-controller="Teacher"
               asp-action="CreateQuiz"
               asp-route-userId="@ViewBag.UserId">
                ➕ Create Quiz
            </a>

            <h5>Your Quizzes</h5>

            @if (ViewBag.Quizzes != null && ViewBag.Quizzes.Count > 0)
            {
                @foreach (var quiz in ViewBag.Quizzes)
                {
                    <div class="quiz-card">
                        <b>@quiz.Title</b>

                        <a class="btn btn-sm btn-light float-end"
                           asp-controller="Teacher"
                           asp-action="ViewQuestions"
                           asp-route-quizId="@quiz.Id"
                           asp-route-userId="@ViewBag.UserId">
                            View
                        </a>
                    </div>
                }
            }
            else
            {
                <p>No quizzes created yet.</p>
            }
        }
        else
        {
            <h4 class="mt-3">Student Dashboard</h4>

            <a class="btn btn-success mt-3"
               asp-controller="Student"
               asp-action="Index"
               asp-route-userId="@ViewBag.UserId">
                🎯 Attempt Quiz
            </a>
        }

    </div>
</div>