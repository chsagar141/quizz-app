@{
    ViewData["Title"] = "Home";
}

<style>
    body {
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .hero {
        height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-card {
        background: rgba(255, 255, 255, 0.85);
        padding: 40px;
        border-radius: 15px;
        text-align: center;
        backdrop-filter: blur(10px);
    }

    h1 {
        font-weight: 600;
    }
</style>

<div class="hero">
    <div class="hero-card">
        <h1>🧠 Online Quiz System</h1>
        <p class="text-muted mt-2">
            Create quizzes, attempt tests, and track performance
        </p>
    </div>
</div>