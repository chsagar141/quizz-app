@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    body {
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .container-main {
        margin-top: 50px;
    }

    .glass-box {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 30px;
        border-radius: 15px;
        color: white;
    }

    p {
        color: #ddd;
    }
</style>

<div class="container container-main">
    <div class="glass-box">

        <h2 class="mb-3">🔒 Privacy Policy</h2>

        <p>
            Your privacy is important to us. This application collects only the necessary
            information required for quiz functionality, such as usernames and quiz attempts.
        </p>

        <p>
            We do not share your personal data with third parties. All data is stored securely
            and used only for educational purposes within the system.
        </p>

        <p>
            By using this application, you agree to the collection and use of information
            in accordance with this policy.
        </p>

    </div>
</div>