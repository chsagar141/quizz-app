<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QuizSystem.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <!-- ✅ NAVBAR -->
    <nav class="navbar navbar-dark bg-dark px-4">
    <span class="navbar-brand fs-4">🧠 Quiz System</span>

    <div>
        @if (ViewBag.Username != null)
        {
            <span class="text-white me-3">Welcome, @ViewBag.Username</span>

            <a class="btn btn-outline-light btn-sm"
               asp-controller="Account"
               asp-action="Logout">
                Logout
            </a>
        }
        else
        {
            <a class="btn btn-outline-light btn-sm me-2" href="/Account/Login">Login</a>
            <a class="btn btn-primary btn-sm" href="/Account/Register">Register</a>
        }
    </div>
</nav>

    <!-- PAGE CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>
