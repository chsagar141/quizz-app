@{
    ViewData["Title"] = "Result";
}

<style>
    body {
        background: url('/images/bg.jpg') no-repeat center center fixed;
        background-size: cover;
    }

    .center-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
    }

    .glass-card {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 40px;
        border-radius: 15px;
        text-align: center;
        color: white;
        width: 400px;
    }

    .score {
        font-size: 2rem;
        font-weight: bold;
        margin-top: 10px;
    }

    .btn-custom {
        margin-top: 20px;
    }
</style>

<div class="center-container">
    <div class="glass-card">

        <h2>🎉 Quiz Completed!</h2>

        <p class="mt-3">Your Score</p>

        <div class="score">
            @ViewBag.Score / @ViewBag.Total
        </div>

        <a class="btn btn-primary btn-custom w-100"
           asp-controller="Dashboard"
           asp-action="Index"
           asp-route-userId="@ViewBag.UserId">
            Back to Dashboard
        </a>

    </div>
</div>